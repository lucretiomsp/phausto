'From Pharo14.0.0SNAPSHOT of 4 August 2025 [Build information: Pharo-14.0.0+SNAPSHOT.build.99.sha.0142ce1f581a7d5641c6c0b56f2051304710047c (64 Bit)] on 16 April 2026 at 8:55:33.410486 am'!Morph subclass: #PhGUISlider	instanceVariableNames: 'address faderCanMove cursor minValue maxValue cursorColor index dsp'	classVariableNames: ''	package: 'Phausto-GUI'!!PhGUISlider commentStamp: '' prior: 0!A Slider for a DSP parameter!!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.844658+02:00'!address ^ address ! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.84479+02:00'!address: anAddress"set address (and labels)"address := anAddress ! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.84489+02:00'!cursorColor^ cursorColor! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.845026+02:00'!cursorColor: aColorcursor color: aColor! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.845529+02:00'!dsp ^ dsp! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.845645+02:00'!dsp: aDSP dsp := aDSP! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.846037+02:00'!index^ index! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.846343+02:00'!index: anIntegerindex := anInteger! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.847252+02:00'!maxValue: aNumbermaxValue := aNumber asFloat .! !!PhGUISlider methodsFor: 'accessing' stamp: '2025-08-06T00:33:15.847388+02:00'!minValue: aNumberminValue := aNumber asFloat .! !!PhGUISlider methodsFor: 'as yet unclassified' stamp: '2025-08-06T00:33:15.845421+02:00'!drawCursor"draw the fader cursor"| cursorWidth cursorHeight |cursorHeight := self extent y /5.cursorWidth := self width.cursor extent: 400@cursorHeight .self addMorph: cursor.cursor center: self center.! !!PhGUISlider methodsFor: 'as yet unclassified' stamp: '2025-08-06T00:33:15.848679+02:00'!mouseMove: anEvent" the VerticalFaderForSuperDirt modify the contents of the Sequencer in Performance named as destination"	| newLocation mappedY cursorY faderBottom range faderTop |	range := maxValue - minValue.   	faderCanMove		ifTrue: [ 			faderBottom := self extent y + self position y.			faderTop := self position y.			cursorY := (anEvent position y min: faderBottom) max: faderTop.			newLocation := Point x: self center x y: cursorY.			cursor center: newLocation.			"map cursorY to value from 0 to 1"			mappedY := (((cursorY min: faderBottom) - faderBottom) abs min:				            self extent y) / self extent y * range + minValue.							dsp setValue: mappedY  parameterIndex: index.				]							ifFalse: [ ] 			! !!PhGUISlider methodsFor: 'as yet unclassified' stamp: '2025-08-06T00:33:15.849641+02:00'!openInWindow   |faderWidth faderHeight positionLeft positionTop  bgColor|faderWidth := 150.faderHeight := self currentWorld height / 2.1.positionLeft := self currentWorld width - faderWidth .positionTop := (self currentWorld submorphs at: 1) extent y + faderHeight .bgColor := Color random lighter lighter.self color: bgColor.self cursorColor: Color black.	^ ((self openInWindowLabeled: address  ) position: (positionLeft @positionTop )) extent: faderWidth@faderHeight.! !!PhGUISlider methodsFor: 'event handling' stamp: '2025-08-06T00:33:15.845748+02:00'!handlesMouseDown: anEvent^ true! !!PhGUISlider methodsFor: 'event handling' stamp: '2025-08-06T00:33:15.845847+02:00'!handlesMouseMove: anEvent^ true! !!PhGUISlider methodsFor: 'event handling' stamp: '2025-08-06T00:33:15.845945+02:00'!handlesMouseUp: anEvent^ true! !!PhGUISlider methodsFor: 'event handling' stamp: '2025-08-06T00:33:15.847503+02:00'!mouseDown: anEventfaderCanMove := true.! !!PhGUISlider methodsFor: 'event handling' stamp: '2025-08-06T00:33:15.848845+02:00'!mouseUp: anEventfaderCanMove := false! !!PhGUISlider methodsFor: 'initialization' stamp: '2025-08-06T00:33:15.84691+02:00'!initialize	super initialize.	faderCanMove := false.	"self extent: 400@500"	cursor := Morph new extent: 400 @ 300.	cursor color: Color red.	self drawCursor! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!PhGUISlider class	instanceVariableNames: ''!!PhGUISlider class commentStamp: '' prior: 0!A Slider for a DSP parameter!!PhGUISlider class methodsFor: 'instance creation' stamp: '2025-08-06T00:33:15.843477+02:00'!closeAll	| fadersInWorld |		fadersInWorld := self  currentWorld submorphs select: [ :i |		                 i class = FaderWindow  ].	fadersInWorld do: [ :i | i delete ]! !!PhGUISlider class methodsFor: 'instance creation' stamp: '2025-08-06T00:33:15.843913+02:00'!newWithAddress: anAddress	" the fader label is also the OSC address"	^ self new		  address: anAddress;		  extent: 200 @ 600;		  color: Color random;		  cursorColor: Color black;		  minValue: 0;		  maxValue: 1;		  yourself! !!PhGUISlider class methodsFor: 'instance creation' stamp: '2025-08-06T00:33:15.844529+02:00'!newWithIndex: anIndex forDSP: aDSP	" the fader label is also the OSC address"	^ self new		  address: ((aDSP getParamAddress: anIndex) allButFirst: 5);		  "cut the first part of the address to get just the parameter name"		  index: anIndex;		  extent: 200 @ 600;		  color: Color random;		  cursorColor: Color black;		  minValue: (aDSP getParamMin: anIndex );		  maxValue: (aDSP getParamMax: anIndex );		  dsp: aDSP;		  yourself! !